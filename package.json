{
  "private": true,
  "scripts": {
    "build": "tailwindcss -i css/app.css -o public/css/tailwind.css --minify && vite build",
    "build:tailwind": "tailwindcss -i css/app.css -o public/css/tailwind.css --minify",
    "build:3d": "vite build && node -e \"const fs=require('fs');const s='public/dist',d='public_html/public/dist';if(fs.existsSync(d))fs.rmSync(d,{recursive:true});fs.cpSync(s,d,{recursive:true});fs.cpSync('public/fonts','public_html/public/fonts',{recursive:true});const imgSrc='public/images/panoramas',imgDst='public_html/public/images/panoramas';if(!fs.existsSync(imgDst)){fs.mkdirSync(imgDst,{recursive:true})}fs.cpSync(imgSrc,imgDst,{recursive:true});\"",
    "watch": "tailwindcss -i css/app.css -o public/css/tailwind.css --watch",
    "dev:3d": "vite"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "laravel-vite-plugin": "^3.1.0",
    "tailwindcss": "^3.4.0",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.184.0"
  }
}
