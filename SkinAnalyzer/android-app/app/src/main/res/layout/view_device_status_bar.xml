<?xml version="1.0" encoding="utf-8"?>
<!--
  view_device_status_bar.xml
  Derma AI — Reusable device status strip shown at top of multiple screens
  Landscape-optimized for ZMLH02
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="40dp"
    android:background="@color/background_dark"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="20dp">

    <!-- Device name -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:letterSpacing="0.06"
        android:text="@string/splash_app_name"
        android:textColor="@color/primary"
        android:textSize="12sp"
        android:textStyle="bold" />

    <View
        android:layout_width="1dp"
        android:layout_height="16dp"
        android:layout_marginHorizontal="12dp"
        android:background="@color/divider" />

    <!-- Connection indicator -->
    <View
        android:id="@+id/dotStatus"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:layout_marginEnd="6dp"
        android:background="@drawable/shape_status_dot_green" />

    <TextView
        android:id="@+id/tvStatusBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_muted"
        android:textSize="11sp"
        tools:text="متصل — ZMLH02 Max" />

    <!-- Spacer -->
    <Space
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Date/Time -->
    <TextView
        android:id="@+id/tvStatusTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_muted"
        android:textSize="11sp"
        tools:text="08:30 م — السبت 7 يونيو 2026" />

    <View
        android:layout_width="1dp"
        android:layout_height="16dp"
        android:layout_marginHorizontal="12dp"
        android:background="@color/divider" />

    <!-- AI engine indicator -->
    <TextView
        android:id="@+id/tvEngine"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_chip_cyan"
        android:paddingHorizontal="8dp"
        android:paddingVertical="2dp"
        android:textColor="@color/primary"
        android:textSize="11sp"
        tools:text="TFLite AI" />
</LinearLayout>
