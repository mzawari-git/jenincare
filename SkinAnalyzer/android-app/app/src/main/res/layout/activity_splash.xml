<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <View
        android:layout_width="800dp"
        android:layout_height="800dp"
        android:layout_gravity="start|top"
        android:layout_marginStart="-300dp"
        android:layout_marginTop="-300dp"
        android:alpha="0.08"
        android:background="@drawable/shape_glow_orb_cyan" />

    <View
        android:layout_width="700dp"
        android:layout_height="700dp"
        android:layout_gravity="end|bottom"
        android:layout_marginEnd="-250dp"
        android:layout_marginBottom="-250dp"
        android:alpha="0.06"
        android:background="@drawable/shape_glow_orb_purple" />

    <View
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:layout_gravity="center"
        android:alpha="0.04"
        android:background="@drawable/shape_glow_orb_cyan" />

    <LinearLayout
        android:id="@+id/splashContent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:alpha="0">

        <FrameLayout
            android:id="@+id/logoContainer"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_gravity="center_horizontal">

            <View
                android:id="@+id/glowRing"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0"
                android:background="@drawable/shape_glow_ring_cyan" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/logoCard"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_gravity="center"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="36dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_glow"
                app:strokeWidth="2dp">

                <ImageView
                    android:id="@+id/ivSplashLogo"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_skin_analyzer"
                    android:scaleType="fitCenter"
                    android:contentDescription="@string/cd_app_logo" />
            </com.google.android.material.card.MaterialCardView>
        </FrameLayout>

        <TextView
            android:id="@+id/tvSplashTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.06"
            android:text="@string/splash_app_name"
            android:textColor="@color/text_primary"
            android:textSize="48sp"
            android:textStyle="bold"
            android:alpha="0" />

        <TextView
            android:id="@+id/tvSplashTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:letterSpacing="0.15"
            android:text="@string/splash_tagline"
            android:textColor="@color/primary"
            android:textSize="16sp"
            android:alpha="0" />

        <LinearLayout
            android:id="@+id/splashFeatures"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:alpha="0">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:background="@drawable/bg_chip_cyan"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="14 مؤشر"
                android:textColor="@color/primary"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:background="@drawable/bg_chip_purple"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="AI متقدم"
                android:textColor="@color/accent_purple"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:background="@drawable/bg_chip_gold"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="5 أوضاع"
                android:textColor="@color/accent_gold"
                android:textSize="12sp" />
        </LinearLayout>

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressSplash"
            style="@style/Progress.Linear"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:indeterminate="true"
            android:alpha="0" />

        <TextView
            android:id="@+id/tvSplashStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/splash_status_initializing"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:alpha="0" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/splashFooter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="36dp"
        android:gravity="center"
        android:orientation="vertical"
        android:alpha="0">

        <TextView
            android:id="@+id/tvDeviceName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/splash_powered_by"
            android:textColor="@color/text_muted"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvDeviceModel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/splash_device_info"
            android:textColor="@color/text_muted"
            android:textSize="11sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="28dp"
        android:background="@drawable/bg_chip_muted"
        android:paddingHorizontal="12dp"
        android:paddingVertical="5dp"
        android:text="@string/splash_version"
        android:textColor="@color/text_muted"
        android:textSize="11sp"
        android:alpha="0" />

</FrameLayout>
