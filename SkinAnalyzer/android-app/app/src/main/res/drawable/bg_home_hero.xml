<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FFD4AF37"
                android:centerColor="#FFEBB868"
                android:endColor="#FFC9952A"
                android:angle="135" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    <item
        android:left="0dp"
        android:top="0dp"
        android:right="0dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#33FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270" />
            <corners android:radius="24dp" />
        </shape>
    </item>
</layer-list>
