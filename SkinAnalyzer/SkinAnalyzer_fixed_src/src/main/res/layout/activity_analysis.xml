<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_analysis.xml
  Derma AI — Scanning / Analysis Screen
  Full-screen scan UI with face guide, progress, instructions
  Landscape 1920×1080
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <!-- Camera preview (fills background) -->
    <TextureView
        android:id="@+id/cameraPreview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Dark overlay on camera -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/scrim" />

    <!-- Top header (transparent overlay) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="top"
        android:background="@color/overlay_top"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelScan"
            style="@style/Button.Icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="16dp"
            app:icon="@drawable/ic_delete"
            app:iconTint="@color/white_70"
            app:cornerRadius="12dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="فحص البشرة"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Spectrum mode indicator -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            app:cardBackgroundColor="@color/surface_glass"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/border_card"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp">

                <View
                    android:id="@+id/dotSpectrum"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/shape_status_dot_cyan" />

                <TextView
                    android:id="@+id/tvSpectrumMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RGB Spectrum"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- Center: Scan circle + face guide -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical">

        <!-- Scan animation container (custom view animates rings) -->
        <FrameLayout
            android:layout_width="420dp"
            android:layout_height="420dp">

            <!-- ScanRingView draws pulsing rings + rotating laser in code -->
            <com.ebtikar.skinanalyzer.ui.scan.ScanRingView
                android:id="@+id/scanRingView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- Face outline guide (SVG) -->
            <ImageView
                android:id="@+id/ivFaceGuide"
                android:layout_width="260dp"
                android:layout_height="320dp"
                android:layout_gravity="center"
                android:alpha="0.6"
                android:src="@drawable/ic_back"
                android:scaleType="fitCenter" />

            <!-- Detection points overlay -->
            <com.ebtikar.skinanalyzer.ui.scan.DetectionPointsView
                android:id="@+id/detectionPoints"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- Center percentage -->
            <TextView
                android:id="@+id/tvScanPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_chip_dark"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="0%"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- Instruction text below circle -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:orientation="vertical">

            <!-- Step counter -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvScanStep"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/primary"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvScanTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" / 8"
                    android:textColor="@color/text_muted"
                    android:textSize="20sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvScanStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="جاري التهيئة..."
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:gravity="center" />

            <TextView
                android:id="@+id/tvScanInstruction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="ضع وجهك في منتصف الدائرة"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:gravity="center" />
        </LinearLayout>

        <!-- Phase indicators -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/phaseCapture"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                app:cardBackgroundColor="@color/primary_light"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/primary"
                app:strokeWidth="1dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:paddingHorizontal="14dp"
                    android:text="التقاط"
                    android:textColor="@color/primary"
                    android:textSize="12sp" />
            </com.google.android.material.card.MaterialCardView>

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_back"
                android:alpha="0.4" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/phaseProcess"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                app:cardBackgroundColor="@color/surface_glass"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_card"
                app:strokeWidth="1dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:paddingHorizontal="14dp"
                    android:text="معالجة"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp" />
            </com.google.android.material.card.MaterialCardView>

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_back"
                android:alpha="0.4" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/phaseAnalyze"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                app:cardBackgroundColor="@color/surface_glass"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_card"
                app:strokeWidth="1dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:paddingHorizontal="14dp"
                    android:text="تحليل"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </LinearLayout>

    <!-- Left sidebar: live metric previews -->
    <LinearLayout
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|start"
        android:layout_marginStart="32dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:letterSpacing="0.08"
            android:text="القراءات الحية"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:textAllCaps="true" />

        <!-- Live metric rows (populated by ViewModel) -->
        <LinearLayout
            android:id="@+id/containerLiveMetrics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </LinearLayout>

    <!-- Right sidebar: spectrum + tips -->
    <LinearLayout
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|end"
        android:layout_marginEnd="32dp"
        android:orientation="vertical">

        <!-- Spectrum selector -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:letterSpacing="0.08"
            android:text="نمط الطيف"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:textAllCaps="true" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface_glass"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/border_card"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/tvCurrentSpectrum"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RGB — ضوء مرئي"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progressSpectrum"
                    style="@style/Progress.Linear"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:indeterminate="true" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Tips card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/accent_gold_light"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/accent_gold"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💡 نصيحة"
                    android:textColor="@color/accent_gold"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvScanTip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="أبعد النظارات وتأكد من إضاءة جيدة للحصول على نتائج دقيقة"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:lineSpacingMultiplier="1.5" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- Bottom progress bar -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progressScan"
        style="@style/Progress.Linear"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:indeterminate="false"
        android:max="100"
        android:progress="0" />

</FrameLayout>
